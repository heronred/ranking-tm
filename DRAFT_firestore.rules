rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // --- GLOBAL HELPERS ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function getRole(uid) { return get(/databases/$(database)/documents/users/$(uid)).data.role; }
    function isAdmin() { return isSignedIn() && getRole(request.auth.uid) == 'admin'; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- USERS ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'category', 'rankingPoints']) &&
               data.keys().size() <= 8 &&
               data.uid == userId &&
               data.displayName is string && data.displayName.size() <= 100 &&
               data.email is string && data.email.size() <= 100 &&
               data.role in ['admin', 'player'] &&
               data.category in ['Federados', 'Não federados', 'Sub 11', '60+'] &&
               data.rankingPoints is number;
      }

      allow get: if isSignedIn();
      allow list: if isAdmin();
      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'player' && incoming().rankingPoints == 1000;
      allow update: if (isOwner(userId) && isValidUser(incoming()) && 
                        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'category']) &&
                        incoming().role == existing().role &&
                        incoming().rankingPoints == existing().rankingPoints) || isAdmin();
    }

    // --- TOURNAMENTS ---
    match /tournaments/{tournamentId} {
      function isValidTournament(data) {
        return data.keys().hasAll(['name', 'category', 'startDate', 'status']) &&
               data.name is string && data.name.size() <= 200 &&
               data.status in ['scheduled', 'ongoing', 'finished'];
      }

      allow read: if isSignedIn();
      allow write: if isAdmin() && isValidTournament(incoming());
    }

    // --- MATCHES ---
    match /matches/{matchId} {
      function isValidMatch(data) {
        return data.keys().hasAll(['player1Id', 'player2Id', 'status', 'type', 'category', 'date']) &&
               data.status in ['scheduled', 'ongoing', 'finished'] &&
               data.type in ['tournament', 'challenge'];
      }

      function isParticipant() {
        return existing().player1Id == request.auth.uid || existing().player2Id == request.auth.uid;
      }

      allow read: if isSignedIn();
      allow create: if (isSignedIn() && isValidMatch(incoming())) || isAdmin();
      allow update: if (isAdmin() && isValidMatch(incoming())) || 
                        (isParticipant() && isValidMatch(incoming()) && 
                         incoming().diff(existing()).affectedKeys().hasOnly(['player1Score', 'player2Score', 'status', 'winnerId', 'updatedAt']));
    }

    // --- CHALLENGES ---
    match /challenges/{challengeId} {
      function isValidChallenge(data) {
        return data.keys().hasAll(['challengerId', 'challengedId', 'status', 'category']) &&
               data.status in ['pending', 'accepted', 'declined', 'completed'];
      }

      allow read: if isSignedIn() && (resource.data.challengerId == request.auth.uid || resource.data.challengedId == request.auth.uid || isAdmin());
      allow create: if isSignedIn() && incoming().challengerId == request.auth.uid && isValidChallenge(incoming());
      allow update: if (isSignedIn() && (resource.data.challengerId == request.auth.uid || resource.data.challengedId == request.auth.uid) && 
                        isValidChallenge(incoming()) &&
                        incoming().diff(existing()).affectedKeys().hasOnly(['status', 'matchId'])) || isAdmin();
    }
  }
}
